  "build": {
    "appId": "com.helminth.streamoverlayreact",
    "productName": "StreamOverlay React",
    "copyright": "Helminth",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron"
